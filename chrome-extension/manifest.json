{
  "manifest_version": 3,
  "name": "Stackly – Link Shortener",
  "version": "1.0.0",
  "description": "Shorten URLs, track clicks, and manage your Stackly links right from your browser.",
  "permissions": ["activeTab", "contextMenus", "storage", "scripting", "notifications", "clipboardWrite"],
  "host_permissions": [
    "https://lestcgentjwlqaozyfft.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
